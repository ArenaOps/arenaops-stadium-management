# ============================================================
# ArenaOps Web — Local Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.local.example .env.local
#
# .env.local is gitignored and never committed.
# Restart the dev server after making changes.
# ============================================================

# ------------------------------------------------------------
# Backend Service URLs (server-side only — no NEXT_PUBLIC_ prefix)
# These are used by the Next.js BFF proxy routes:
#   /api/core/[...slug]  →  CORE_SERVICE_URL
#   /api/auth/[...slug]  →  AUTH_SERVICE_URL
# ------------------------------------------------------------

# URL of the ArenaOps Core Service REST API
CORE_SERVICE_URL=http://localhost:5007/api

# URL of the ArenaOps Auth Service REST API
AUTH_SERVICE_URL=http://localhost:5001/api/auth

# ------------------------------------------------------------
# Frontend Base URL (exposed to both server and browser)
# Used by the axios client when making server-side requests
# ------------------------------------------------------------
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ------------------------------------------------------------
# Google OAuth
# ------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID

# ------------------------------------------------------------
# Cloudinary (server-side only)
# ------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
