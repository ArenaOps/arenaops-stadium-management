# ============================================================
#  ArenaOps — EC2 Environment Variables
#  Copy this file to .env on your EC2 server and fill in values.
#  NEVER commit the real .env file to git.
# ============================================================

# ── EC2 ──────────────────────────────────────────────────────
EC2_PUBLIC_IP=YOUR_EC2_PUBLIC_IP
FRONTEND_URL=https://yourapp.netlify.app  # Your deployed frontend URL (for CORS)
DOMAIN_NAME=yourdomain.com                # Optional — leave blank if no domain yet

# ── AuthService Database (MonsterDB) ─────────────────────────
AUTH_DB_CONNECTION=Server=db41261.public.databaseasp.net;Database=db41261;User Id=db41261;Password=YOUR_AUTH_DB_PASSWORD;Encrypt=True;TrustServerCertificate=True;MultipleActiveResultSets=True;

# ── CoreService Database (MonsterDB) ─────────────────────────
CORE_DB_CONNECTION=Server=db41847.public.databaseasp.net;Database=db41847;User Id=db41847;Password=YOUR_CORE_DB_PASSWORD;Encrypt=True;TrustServerCertificate=True;MultipleActiveResultSets=True;

# ── Google OAuth ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# ── SMTP Email ────────────────────────────────────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=YOUR_EMAIL@gmail.com
SMTP_PASSWORD=YOUR_APP_PASSWORD
SMTP_FROM_EMAIL=YOUR_EMAIL@gmail.com
