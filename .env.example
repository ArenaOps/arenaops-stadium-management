# ArenaOps Environment Variables
# Using hosted databases (no Docker required)

# AuthService DB (MonsterASP)
# Configure in: BACKEND/ArenaOps.AuthService/ArenaOps.AuthService.API/appsettings.Development.json
# Key: ConnectionStrings:AuthDb

# CoreService DB (MonsterASP)
# Configure in: BACKEND/ArenaOps.CoreService/ArenaOps.CoreService.API/appsettings.Development.json
# Key: ConnectionStrings:CoreDb

# Redis (deferred — will use hosted provider later)
# Key: ConnectionStrings:Redis

# ---------------------------------------------------------------
# Frontend (Next.js) — FRONTEND/arenaops-web/.env.local
# ---------------------------------------------------------------
# Copy FRONTEND/arenaops-web/.env.local.example to
# FRONTEND/arenaops-web/.env.local and set the values below.
#
# CORE_SERVICE_URL=http://localhost:5007/api   # ArenaOps Core Service URL
# AUTH_SERVICE_URL=http://localhost:5001/api/auth  # ArenaOps Auth Service URL
# NEXT_PUBLIC_BASE_URL=http://localhost:3000   # Frontend base URL
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
